# ──────────────────────────────────────────────────────────────────────────
# CRM — environment template.  Copy to `.env` and fill real values.
# NEVER commit a real .env.  All secrets are env-driven.
# ──────────────────────────────────────────────────────────────────────────

# --- App ---
APP_NAME=CRM
APP_VERSION=0.8.0
NODE_ENV=development
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# --- Hardening / ops ---
THROTTLE_LIMIT=200          # requests per window per IP per route
THROTTLE_TTL=60000          # window in ms
LOG_LEVEL=info              # pino level (trace|debug|info|warn|error)
DISABLE_CRON=false          # set true on one-off worker processes

# --- Postgres ---
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_dev_password
POSTGRES_DB=crm
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Server ---
SERVER_PORT=4000
# Used by the server container; for local (non-docker) dev point at localhost.
DATABASE_URL=postgresql://crm:crm_dev_password@localhost:5432/crm?schema=public
REDIS_URL=redis://localhost:6379

# --- Auth / JWT (generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=change_me_access_32_bytes_hex
JWT_REFRESH_SECRET=change_me_refresh_32_bytes_hex
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=1209600     # seconds (14 days)

# --- Cookies / CORS ---
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false         # true in production (HTTPS)
CORS_ORIGIN=http://localhost:5173

# --- Web ---
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:4000

# ──────────────────────────────────────────────────────────────────────────
# Provider credentials below are NOT used until later phases. They are
# documented here so deployment configs are complete. Leave blank for now.
# Each provider is isolated behind an adapter (src/integrations/adapters).
# ──────────────────────────────────────────────────────────────────────────

# --- Email (default adapter: Amazon SES) ---
EMAIL_PROVIDER=ses
AWS_SES_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=

# --- WhatsApp (default adapter: Meta Cloud API) ---
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# --- SMS (default adapter: MSG91) ---
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_DLT_TEMPLATE_ID=

# --- Voice (default adapter: Exotel) ---
VOICE_PROVIDER=exotel
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=

# --- Meta Lead Ads (App-level webhook, Phase 3) ---
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0

# --- S3 / object storage (attachments, recordings, exports) ---
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Error monitoring (optional) ---
SENTRY_DSN=
